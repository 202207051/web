<div class="my-5">
    <h1 class="text-center my-4 fw-bold text-primary">학생관리</h1>

    <div class="text-end mb-3">
        <a class="btn btn-primary px-4 fw-bold" href="/haksa/stu/insert">학생등록</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table id="tbl" class="table table-striped table-hover mb-0 text-center align-middle">
                <thead class="table-primary">
                    <tr>
                        <th style="width: 12%;">학번</th>
                        <th style="width: 15%;">학생명</th>
                        <th style="width: 18%;">소속학과</th>
                        <th style="width: 15%;">생년월일</th>
                        <th style="width: 10%;">학년</th>
                        <th style="width: 20%;">지도교수(교수번호)</th>
                        <th style="width: 10%;">관리</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>

    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}    
            <tr>
                <td class="fw-bold text-secondary">{{SCODE}}</td>    
                <td>{{SNAME}}</td>    
                <td><span class="badge bg-light text-dark border">{{DEPT}}</span></td>    
                <td>{{FDATE}}</td>    
                <td>{{YEAR}}학년</td>    
                <td>{{PNAME}} 교수 <small class="text-muted">({{ADVISOR}})</small></td>    ]
                <td>
                    <button class="btn btn-danger btn-sm" scode="{{SCODE}}">삭제</button>    ]
                </td>
            </tr>
            {{/each}}    ]
        </tbody>
    </script> ]
</div>

<script>
    getList();

    // 삭제 버튼을 클릭한 경우의 처리
    $("#tbl").on("click", ".btn-sm", function () {
        const scode = $(this).attr("scode");
        if (confirm(`${scode}번 학생을 삭제하실래요?`)) {
            $.ajax({
                type: "post",
                url: "/haksa/stu/delete",
                data: { scode },
                success: function () {
                    alert("학생 정보가 삭제되었습니다.");
                    getList();
                },
                error: function () {
                    alert("학생 삭제를 실패했습니다.");
                }
            })
        }
    });

    // 학생 데이터 리스트를 백엔드에서 받아오는 함수
    function getList() {
        $.ajax({
            type: "get",
            url: "/haksa/stu/list.json",
            success: function (data) {
                console.log(data);
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            }
        })
    }
</script>