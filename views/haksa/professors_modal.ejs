<button type="button" class="btn btn-outline-secondary fw-bold" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
  🔍 교수 검색
</button>

<div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg"> 
    <div class="modal-content shadow">
      
      <div class="modal-header bg-dark text-white">
        <h1 class="modal-title fs-5 fw-bold" id="staticBackdropLabel">👨‍🏫 담당 교수 검색</h1>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <div class="modal-body p-0" style="max-height: 400px; overflow-y: auto;">
        <table id="tbl_modal" class="table table-striped table-hover mb-0 text-center align-middle">
          <thead class="table-light sticky-top"> 
            <tr>
              <th style="width: 30%;">교수번호</th>
              <th style="width: 40%;">교수이름</th>
              <th style="width: 30%;">소속학과</th>
            </tr>
          </thead>
        </table>
      </div>
      
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary fw-bold" data-bs-dismiss="modal">닫기</button>
      </div>
      
    </div>
  </div>
</div>

<script id="temp" type="text/x-handlebars-template">
    <tbody>
        {{#each .}}
        <tr>
            <td class="fw-bold text-secondary">{{PCODE}}</td>
            <td><a href="{{PCODE}}" class="text-decoration-none fw-bold text-primary">{{PNAME}}</a></td>
            <td><span class="badge bg-light text-dark border">{{DEPT}}</span></td>                        
        </tr>
        {{/each}}
    </tbody>
</script>

<script>
    getList();

    // 교수 이름을 클릭한 경우의 처리 (부모 폼으로 데이터 전달)
    // 테이블 ID가 변경됨에 따라 선택자를 #tbl_modal로 수정했습니다
    $("#tbl_modal").on("click", "a", function(e){
        e.preventDefault(); // 링크 이동 방지 
        const pcode = $(this).attr("href"); // 클릭한 교수의 PCODE 가져오기 [cite: 40]
        
        // 부모 입력 폼(frm)의 pcode 입력란에 값을 채워넣습니다 [cite: 40]
        $(frm.pcode).val(pcode); 
        
        // 데이터 입력 후 모달창을 닫아줍니다 [cite: 40]
        $("#staticBackdrop").modal("hide"); 
    });

    // 교수 목록을 불러오는 AJAX 함수
    function getList(){
        $.ajax({
            type: "get",
            url: "/haksa/pro/list.json", // 교수 데이터 JSON API 주소 [cite: 42]
            success: function(data){
                console.log(data); // 콘솔 디버깅 로그 보존 [cite: 42]
            
                const temp = Handlebars.compile($("#temp").html()); // 핸들바 컴파일 [cite: 43]
                // 데이터를 출력할 대상 테이블을 #tbl_modal로 수정했습니다
                $("#tbl_modal").html(temp(data)); 
            }
        })
    }
</script>