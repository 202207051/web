<div class="my-5">
    <h1 class="text-center mb-4 fw-bold text-primary"><%=title%></h1> 
    
    <div class="text-end mb-3">
        <a class="btn btn-primary px-4 fw-bold" href="/haksa/pro/insert">교수등록</a> 
    </div>
    
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table id="tbl" class="table table-striped table-hover mb-0 text-center align-middle">
                <thead class="table-primary">
                    <tr>
                        <th style="width: 12%;">교수번호</th>
                        <th style="width: 15%;">교수명</th>
                        <th style="width: 20%;">담당학과</th>
                        <th style="width: 15%;">직위</th>
                        <th style="width: 15%;">임용일자</th>
                        <th style="width: 13%;">급여</th>
                        <th style="width: 10%;">관리</th>
                    </tr>
                </thead>
                </table>
        </div>
    </div>

    <script id="temp" type="text/x-handlebars-template">
        <tbody>
            {{#each .}}
            <tr>
                <td class="fw-bold text-secondary">{{PCODE}}</td> 
                <td>{{PNAME}}</td>  
                <td>{{DEPT}}</td>  
                <td><span class="badge bg-light text-dark border">{{TITLE}}</span></td>  
                <td>{{FDATE}}</td>  
                <td>{{FSALARY}}원</td>  
                <td>
                    <button class="btn btn-danger btn-sm delete" pcode="{{PCODE}}">삭제</button>  
                </td>
            </tr>
            {{/each}}
        </tbody>
    </script>
</div>

<script>    
    getList(); 

    // 삭제 버튼을 클릭한 경우
    $("#tbl").on("click", ".delete", function(){
        const pcode = $(this).attr("pcode"); 
        if(confirm(`${pcode}번 교수를 삭제하실래요?`)){ 
            $.ajax({
                type: "post",
                url: "/haksa/pro/delete", 
                data: {pcode}, 
                success: function(){ 
                    alert("삭제가 완료되었습니다."); 
                    getList(); 
                },
                error: function(){ 
                    alert("삭제를 실패했습니다."); 
                }
            })
        }
    });

    // 교수 목록을 백엔드에서 받아와 화면에 그려주는 함수
    function getList(){ 
        $.ajax({
            type: "get",
            url: "/haksa/pro/list.json", 
            success: function(data){ 
                console.log(data); 
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data)); 
            }
        })
    }
</script>