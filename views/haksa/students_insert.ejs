<div class="row justify-content-center my-5">
    <div class="col col-xl-6 col-lg-8 col-md-10">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white text-center p-3">
                <h3 class="mb-0 fw-bold">👨‍🎓 신규 학생 등록</h3>
            </div>
            <div class="card-body p-4">
                <form name="frm" method="post">
                    <div class="input-group mb-3">
                        <span class="input-group-text justify-content-center" style="width: 100px;">학생번호</span>
                        <input name="scode" class="form-control bg-light" readonly value="<%=code%>">
                    </div>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text justify-content-center" style="width: 100px;">학생이름</span>
                        <input name="sname" class="form-control" placeholder="학생 이름을 입력하세요">
                    </div>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text justify-content-center" style="width: 100px;">학생학과</span>
                        <select name="dept" class="form-select">
                            <option value="전산">전산</option>
                            <option value="전자">전자</option>
                            <option value="건축">건축</option>
                        </select>
                    </div>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text justify-content-center" style="width: 100px;">학생학년</span>
                        <select name="year" class="form-select">
                            <option value="1">1학년</option>
                            <option value="2">2학년</option>
                            <option value="3">3학년</option>
                        </select>
                    </div>
                    
                    <div class="input-group mb-3">
                        <span class="input-group-text justify-content-center" style="width: 100px;">생년월일</span>
                        <input name="birthday" class="form-control" type="date" value="2006-01-01">
                    </div>
                    
                    <div class="input-group mb-4">
                        <span class="input-group-text justify-content-center" style="width: 100px;">지도교수</span>
                        <input name="pcode" class="form-control bg-light" readonly placeholder="우측 버튼을 눌러 선택하세요">   
                        <%-include("professors_modal.ejs")%>             
                    </div>
                    
                    <div class="text-center mt-3">
                        <button type="submit" class="btn btn-primary px-4 me-2 fw-bold">학생등록</button>
                        <button type="reset" class="btn btn-secondary px-4 fw-bold">등록취소</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    $(frm).on("submit", function(e){
        e.preventDefault(); // 기본 submit 페이지 새로고침 방지
        
        const scode = $(frm.scode).val();
        const sname = $(frm.sname).val();
        const dept = $(frm.dept).val();
        const birthday = $(frm.birthday).val();
        const year = $(frm.year).val();
        const pcode = $(frm.pcode).val();
        
        // 이름 필수 유효성 조건 체크
        if(sname == "") {
            alert("학생이름을 반드시 입력하세요!");
            $(frm.sname).focus();
        } else {
            if(!confirm("새로운 학생을 등록하시겠습니까?")) return;
            
            $.ajax({
                type: "post",
                url: "/haksa/stu/insert",
                data: {scode, sname, dept, birthday, year, pcode},
                success: function(){
                    alert("새로운 학생을 등록했습니다.");
                    location.href = "/haksa/stu"; // 등록 성공 후 학생 리스트 목록으로 이동
                },
                error: function(){
                    alert("학생등록을 실패했습니다.");
                }
            });
        }
    });
</script>