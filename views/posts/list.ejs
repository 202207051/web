<div class="my-5">
    <h1 class="text-center mb-5 fw-bold text-primary">게시판</h1>

    <div class="row mb-3">
        <div class="col-md-8 col-xl-6">
            <form name="frm" class="input-group">
                <select name="key" class="form-select me-1" style="max-width: 120px;">
                    <option value="title">제목</option>
                    <option value="body">내용</option>
                    <option value="writer">작성자</option>
                </select>
                <input name="word" class="form-control" placeholder="검색어를 입력하세요">
                <button class="btn btn-primary">검색</button>
            </form>
        </div>
        <div class="col text-end">
            <a href="/posts/insert" class="btn btn-primary px-4 fw-bold">글쓰기</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <table id="tbl" class="table table-striped table-hover mb-0 text-center align-middle">
                <thead class="table-primary">
                    <tr>
                        <th style="width: 10%;">번호</th>
                        <th style="width: 45%;">제목</th>
                        <th style="width: 15%;">작성자</th>
                        <th style="width: 20%;">작성일자</th>
                        <th style="width: 10%;">조회수</th>
                    </tr>
                </thead>
                </table>
        </div>
    </div>

    <div class="d-flex justify-content-center my-4" id="pagination">
        <button class="btn btn-outline-secondary btn-sm me-2 id="btn-prev">이전</button>
        <span class="align-self-center mx-2 fw-bold" id="page-info">1 / 1</span>
        <button class="btn btn-outline-secondary btn-sm ms-2" id="btn-next">다음</button>
    </div>
</div>

<script id="temp" type="text/x-handlebars-template">
    <tbody>
        {{#each .}}
        <tr>
            <td class="text-secondary fw-bold">{{PID}}</td>
            <td class="text-start ps-4">
                <a href="/posts/read/{{PID}}" class="text-decoration-none fw-bold text-dark">{{TITLE}}</a>
            </td>
            <td>{{WRITER}}</td>
            <td>{{FDATE}}</td>
            <td><span class="badge bg-light text-secondary border">{{VIEWCNT}}</span></td>
        </tr>
        {{/each}}
    </tbody>
</script>

<script>
    let page = 1; // 현재 페이지 기본값

    getList();

    // 게시판 데이터 리스트를 백엔드 API에서 받아오는 함수
    function getList(){
        const key = $(frm.key).val();
        const word = $(frm.word).val();

        $.ajax({
            type: "get",
            url: "/posts/list.json",
            data: { page, key, word },
            success: function(data){
                console.log(data);
                // 핸들바 컴파일 및 데이터 맵핑
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data.list));
                
                // 페이지 정보 업데이트 (예: 1 / 5)
                if(data.total == 0) {
                    $("#page-info").html("0 / 0");
                } else {
                    $("#page-info").html(`${page} / ${data.total}`);
                }
            },
            error: function() {
                // 샘플 가이드 데이터 구동 (백엔드 라우터 구현 전 화면 확인용)
                const samplePosts = [
                    { PID: 3, TITLE: '2026학년도 1학기 수강신청 기간 안내', WRITER: '박영환', FDATE: '2026-03-02', VIEWCNT: 45 },
                    { PID: 2, TITLE: '학사관리 웹 프로젝트 공지사항', WRITER: '박영환', FDATE: '2026-02-15', VIEWCNT: 120 },
                    { PID: 1, TITLE: '첫 게시글 테스트입니다.', WRITER: '관리자', FDATE: '2026-01-10', VIEWCNT: 8 }
                ];
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(samplePosts));
                $("#page-info").html("1 / 1");
            }
        });
    }

    // 검색 폼 서브밋 처리
    $(frm).on("submit", function(e){
        e.preventDefault();
        page = 1;
        getList();
    });
</script>